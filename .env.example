# Spinel radio URL. Leave empty to enable USB auto-discovery.
OTBR_RADIO_URL=

# UART baud rate (default: 460800)
OTBR_BAUDRATE=460800

# REST API and dashboard port (default: 8081)
OTBR_PORT=8081

# USB auto-discovery (default: true)
OTBR_AUTO_DISCOVER=true

# Log level: debug, info, warn, error (default: info)
OTBR_LOG_LEVEL=info

# Persistent state directory (default: /data)
OTBR_STATE_DIR=/data

# Backbone interface for border routing (auto-detected if unset)
# OTBR_BACKBONE_IF=eth0

# Hardware UART flow control (default: false)
# OTBR_FLOW_CONTROL=false

# Mock mode for local development without hardware (default: false)
# OTBR_MOCK_MODE=false
